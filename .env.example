# Base de datos (MariaDB / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=data_productos
PORT=3000

# --- Blockchain (Ganache) ---
# RPC del nodo local. Ganache GUI usa el puerto 7545; el CLI usa 8545.
GANACHE_RPC_URL=http://127.0.0.1:7545
# Private key de una de las cuentas que Ganache muestra al abrir el workspace.
# Esta cuenta sera el "organizador" de los eventos on-chain.
BLOCKCHAIN_PRIVATE_KEY=0x_pega_aqui_una_private_key_de_Ganache
# Pon "false" para desactivar la escritura on-chain (la app seguira funcionando solo-BD).
BLOCKCHAIN_ENABLED=true
