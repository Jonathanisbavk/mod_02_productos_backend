# Base de datos (MariaDB / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=data_productos
PORT=3000

# --- Blockchain (Ganache) ---
# RPC del nodo local. Ganache GUI usa el puerto 7545; el CLI usa 8545.
GANACHE_RPC_URL=http://127.0.0.1:7545
# Private key de una de las cuentas que Ganache muestra al abrir el workspace.
# Esta cuenta sera el "organizador" de los eventos on-chain.
BLOCKCHAIN_PRIVATE_KEY=0x_pega_aqui_una_private_key_de_Ganache
# Pon "false" para desactivar la escritura on-chain (la app seguira funcionando solo-BD).
BLOCKCHAIN_ENABLED=true

# --- IPFS (Lab 14: PDF del boleto publicado en IPFS) ---
# API del nodo IPFS local (Kubo / IPFS Desktop). Si no esta corriendo, el PDF se
# genera igual y queda solo local en /pdfs (subida best-effort).
IPFS_URL=http://127.0.0.1:5001
# Gateway para leer los archivos publicados (puedes usar http://127.0.0.1:8080/ipfs para el local).
IPFS_GATEWAY=https://ipfs.io/ipfs

# URL publica de la API, usada en el QR de verificacion del boleto PDF. Por defecto
# es http://localhost:PORT (solo funciona en esta maquina). Para que el QR funcione
# desde cualquier celular, expon la API con un tunel (p. ej. "ngrok http 3000") y pega
# aqui la URL que te de; luego regenera los PDFs.
# API_PUBLIC_URL=https://tu-tunel.ngrok-free.app
